DATABASE_URL="postgresql://user:password@localhost:5432/atlas_dev"

# Clerk Authentication — required for Google SSO
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# AI Configuration — set ONE of these for real AI screening (optional)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides (auto-detected from which key is set)
# AI_PROVIDER=openai       # or "anthropic"
# AI_MODEL=gpt-4o          # or "claude-sonnet-4-20250514"
# AI_ENCRYPTION_KEY=        # 64-char hex for encrypting DB-stored keys
