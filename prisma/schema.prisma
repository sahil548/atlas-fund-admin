generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum EntityType {
  MAIN_FUND
  SIDECAR
  SPV
  CO_INVEST_VEHICLE
  GP_ENTITY
  HOLDING_COMPANY
}

enum VehicleStructure {
  LLC
  LP
  CORP
  TRUST
}

enum EntityStatus {
  ACTIVE
  WINDING_DOWN
  DISSOLVED
}

enum FormationStatus {
  NOT_STARTED
  FORMING
  FORMED
  REGISTERED
}

enum AssetClass {
  REAL_ESTATE
  PUBLIC_SECURITIES
  OPERATING_BUSINESS
  INFRASTRUCTURE
  COMMODITIES
  DIVERSIFIED
  NON_CORRELATED
  CASH_AND_EQUIVALENTS
}

enum CapitalInstrument {
  DEBT
  EQUITY
}

enum ParticipationStructure {
  DIRECT_GP
  CO_INVEST_JV_PARTNERSHIP
  LP_STAKE_SILENT_PARTNER
}

enum AssetStatus {
  ACTIVE
  EXITED
  WRITTEN_OFF
}

enum DealStage {
  SCREENING
  DUE_DILIGENCE
  IC_REVIEW
  CLOSING
  CLOSED
  DEAD
}

enum ClosingChecklistStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETE
}

enum NotificationType {
  STAGE_CHANGE
  IC_VOTE
  DOCUMENT_UPLOAD
  CAPITAL_CALL
  TASK_ASSIGNED
  CLOSING_UPDATE
  GENERAL
  DISTRIBUTION
  REPORT
}

// DealCategory removed — deals now use AssetClass + CapitalInstrument + ParticipationStructure

enum ICQuestionStatus {
  OPEN
  RESOLVED
  DEFERRED
}

enum AccountingProvider {
  QBO
  XERO
}

enum SyncStatus {
  CONNECTED
  SYNCING       // Set by accounting sync route (api/accounting/connections/[id]/sync) — actively used
  DISCONNECTED
  ERROR
}

enum ValuationMethod {
  COMPARABLE_MULTIPLES
  LAST_ROUND
  DCF
  APPRAISAL
  GP_REPORTED_NAV
  COST
}

enum ValuationStatus {
  DRAFT
  APPROVED
}

enum CapitalCallStatus {
  DRAFT
  ISSUED
  FUNDED
  PARTIALLY_FUNDED
  OVERDUE
}

enum DistributionStatus {
  DRAFT
  APPROVED
  PAID
}

enum CovenantType {
  FINANCIAL
  NEGATIVE
  AFFIRMATIVE
  REPORTING
}

enum CovenantStatus {
  COMPLIANT
  WATCH
  CURE_PERIOD
  BREACH
  WAIVED
}

enum LeaseType {
  GROSS
  NET
  NNN
  MODIFIED_GROSS
  PERCENTAGE
}

enum LeaseStatus {
  ACTIVE
  EXPIRED
  MONTH_TO_MONTH
  TERMINATED
}

enum CreditAgreementType {
  LOAN_AGREEMENT
  NOTE_PURCHASE
  PARTICIPATION
  CREDIT_FACILITY
  INDENTURE
  BRIDGE_LOAN
}

enum InterestRateType {
  FIXED
  FLOATING
  HYBRID
  PIK
}

enum CreditStatus {
  PERFORMING
  WATCH
  DEFAULT
  WORKOUT
}

enum Subordination {
  SENIOR
  MEZZANINE
  SUBORDINATED
}

enum PaymentFrequency {
  MONTHLY
  QUARTERLY
  SEMI_ANNUAL
  ANNUAL
}

enum DayCount {
  THIRTY_360
  ACTUAL_360
  ACTUAL_365
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  ARCHIVED
}

enum UserRole {
  GP_ADMIN
  GP_TEAM
  SERVICE_PROVIDER
  LP_INVESTOR
}

enum InviteStatus {
  ACCEPTED
  PENDING   // Set by invite route (api/users/invite) and shown in settings page — actively used
}

enum NotificationChannel {
  EMAIL
  SMS
  PORTAL_ONLY
}

enum DigestPreference {
  IMMEDIATE
  DAILY_DIGEST
  WEEKLY_DIGEST
}

enum MeetingSource {
  FIREFLIES
  MANUAL
  ZOOM
  TEAMS
}

enum DocumentCategory {
  BOARD
  FINANCIAL
  LEGAL
  GOVERNANCE
  VALUATION
  STATEMENT
  TAX
  REPORT
  NOTICE
  OTHER
}

enum ExtractionStatus {
  NONE
  PENDING
  PROCESSING
  COMPLETE
  FAILED
}

enum IncomeType {
  INTEREST
  DIVIDEND
  RENTAL
  ROYALTY
  FEE
  OTHER
}

enum TransactionType {
  CAPITAL_CALL
  DISTRIBUTION
  INCOME
  EXPENSE
  FEE
  TRANSFER
  INVESTMENT
  EXIT
}

enum DDWorkstreamStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETE
}

enum SideLetterRuleType {
  FEE_DISCOUNT
  CARRY_OVERRIDE
  MFN
  CO_INVEST_RIGHTS
  CUSTOM
}

enum ContactType {
  INTERNAL
  EXTERNAL
}

enum CompanyType {
  GP
  LP
  COUNTERPARTY
  SERVICE_PROVIDER
  OPERATING_COMPANY
  OTHER
}

// ============================================================
// CORE: Firm, Entity, User, Accounting
// ============================================================

model Firm {
  id        String   @id @default(cuid())
  name      String
  legalName String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entities Entity[]
  users    User[]
  deals    Deal[]
  ddCategoryTemplates DDCategoryTemplate[]
  companies  Company[]
  contacts   Contact[]
  aiConfiguration AIConfiguration?
  aiPromptTemplates AIPromptTemplate[]
  decisionStructures DecisionStructure[]
  auditLogs  AuditLog[]
  integrationConnections IntegrationConnection[]
  contactInteractions ContactInteraction[] @relation("FirmContactInteractions")
  contactTags         ContactTag[]         @relation("FirmContactTags")
}

model AIConfiguration {
  id             String   @id @default(cuid())
  firmId         String   @unique
  provider       String   @default("openai")
  model          String   @default("gpt-4o")
  apiKey         String?
  apiKeyIV       String?
  apiKeyTag      String?
  baseUrl        String?
  systemPrompt   String?
  thresholdScore Int      @default(70)
  maxDocuments   Int      @default(10)
  processingMode String   @default("async")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  firm Firm @relation(fields: [firmId], references: [id])
}

model AIPromptTemplate {
  id          String   @id @default(cuid())
  firmId      String
  type        String                          // e.g. "SCREENING", "DD_FINANCIAL", "JOURNAL_ENTRY_REVIEW"
  module      String   @default("deals")      // e.g. "deals", "accounting", "entities"
  name        String
  description String?
  content     String                          // The actual prompt text
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  firm Firm @relation(fields: [firmId], references: [id])

  @@unique([firmId, type])
  @@index([firmId])
  @@index([firmId, module])
}

model Entity {
  id               String          @id @default(cuid())
  firmId           String
  name             String
  legalName        String?
  entityType       EntityType
  parentEntityId   String?
  vehicleStructure VehicleStructure @default(LLC)
  ein              String?
  stateOfFormation String?
  formationDate    DateTime?
  status           EntityStatus    @default(ACTIVE)

  // Fund terms
  vintageYear        Int?
  targetSize         Float?
  totalCommitments   Float?
  investmentPeriodEnd DateTime?
  fundTermYears      Int?
  extensionOptions   String?
  fiscalYearEnd      String?

  // Regulatory
  regulatoryFilings Json?
  legalCounsel      String?
  taxPreparer       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  firm                 Firm                  @relation(fields: [firmId], references: [id])
  parentEntity         Entity?               @relation("EntityParent", fields: [parentEntityId], references: [id])
  childEntities        Entity[]              @relation("EntityParent")
  accountingConnection AccountingConnection?
  assetAllocations     AssetEntityAllocation[]
  commitments          Commitment[]
  sideLetters          SideLetter[]
  capitalCalls         CapitalCall[]
  distributions        DistributionEvent[]
  navComputations      NAVComputation[]
  waterfallTemplate    WaterfallTemplate?    @relation("EntityWaterfall", fields: [waterfallTemplateId], references: [id])
  waterfallTemplateId  String?
  feeCalculations      FeeCalculation[]
  capitalAccounts      CapitalAccount[]
  incomeEvents         IncomeEvent[]
  assetExpenses        AssetExpense[]
  transactions         Transaction[]
  documents            Document[]
  meetings             Meeting[]
  deals                Deal[]             @relation("DealTargetEntity")
  tasks                Task[]
  notes                Note[]
  esignaturePackages   ESignaturePackage[]
  fundraisingRounds    FundraisingRound[]
  formationStatus      FormationStatus    @default(FORMED)
  dealEntities         DealEntity[]
  decisionStructureId  String?
  decisionStructure    DecisionStructure? @relation("EntityDecisionStructure", fields: [decisionStructureId], references: [id])
  fundingSources       EntityFundingSource[]

  // Phase 3: NAV proxy configuration
  navProxyConfig       Json?              // { cashPercent, otherAssetsPercent, liabilitiesPercent }
  contactInteractions  ContactInteraction[] @relation("EntityContactInteractions")
  savedConversations   SavedConversation[]
  unitClasses          UnitClass[]

}

model AccountingConnection {
  id                  String             @id @default(cuid())
  entityId            String             @unique
  provider            AccountingProvider
  providerCompanyId   String?
  providerCompanyName String?
  oauthCredentials    Json?
  syncStatus          SyncStatus         @default(DISCONNECTED)
  lastSyncAt          DateTime?
  lastSyncError       String?
  syncFrequency       String             @default("15min")
  chartOfAccountsMapped Boolean          @default(false)
  unreconciledItems   Int                @default(0)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  entity                 Entity                  @relation(fields: [entityId], references: [id])
  accountMappings        AccountMapping[]
  trialBalanceSnapshots  TrialBalanceSnapshot[]
}

model AccountMapping {
  id                String @id @default(cuid())
  connectionId      String
  atlasAccountType  String
  providerAccountId String?
  providerAccountName String?
  isAutoDetected    Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  connection AccountingConnection @relation(fields: [connectionId], references: [id])
}

model TrialBalanceSnapshot {
  id            String   @id @default(cuid())
  connectionId  String
  periodDate    DateTime              // as-of date (e.g., month-end)
  accountData   Json                  // array of { accountId, accountName, accountType, debit, credit, balance }
  totalDebits   Float
  totalCredits  Float
  isBalanced    Boolean  @default(true)  // debits == credits check
  syncedAt      DateTime @default(now()) // when this snapshot was pulled
  createdAt     DateTime @default(now())

  connection AccountingConnection @relation(fields: [connectionId], references: [id])

  @@unique([connectionId, periodDate])
  @@index([connectionId, periodDate])
}

model User {
  id        String   @id @default(cuid())
  firmId    String
  email     String   @unique
  name      String
  role      UserRole
  initials  String?
  isActive     Boolean      @default(true)
  inviteStatus InviteStatus @default(ACCEPTED)

  // Service provider scoping
  entityAccess    String[]  @default([])
  accessExpiresAt DateTime?

  // GP_TEAM configurable permissions per area (null = use defaults)
  permissions Json?

  // AI access control — admin toggles this per user
  aiEnabled        Boolean  @default(true)
  // Personal AI config override — { provider, model, apiKey, apiKeyIV, apiKeyTag }
  personalAiConfig Json?

  slackUserId String?

  // Fireflies per-user integration
  firefliesApiKey     String?
  firefliesApiKeyIV   String?
  firefliesApiKeyTag  String?
  firefliesEmail      String?
  firefliesLastSync   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Link to CRM contact record (a user IS a person)
  contactId          String?  @unique
  contact            Contact? @relation(fields: [contactId], references: [id])

  firm               Firm              @relation(fields: [firmId], references: [id])
  assignedTasks      Task[]
  icVoteRecords      ICVoteRecord[]
  investorAccess     InvestorUserAccess[]
  notes              Note[]
  icQuestions        ICQuestion[]      @relation("ICQuestionAuthor")
  icQuestionReplies  ICQuestionReply[] @relation("ICQuestionReplyAuthor")
  icDecisions        ICProcess[]       @relation("ICDecisions")
  dealsLead          Deal[]            @relation("DealLead")
  closingAssignments ClosingChecklist[] @relation("ClosingAssignments")
  notifications      Notification[]    @relation("UserNotifications")
  assignedWorkstreams DDWorkstream[]   @relation("WorkstreamAssignee")
  workstreamComments  DDWorkstreamComment[] @relation("WorkstreamCommentAuthor")
  taskComments        DDTaskComment[]       @relation("TaskCommentAuthor")
  decisionMemberships DecisionMember[]
  auditLogs           AuditLog[]
  contactInteractions ContactInteraction[] @relation("UserContactInteractions")
  savedConversations  SavedConversation[] @relation("UserSavedConversations")
}

// ============================================================
// ASSETS
// ============================================================

model Asset {
  id                     String                @id @default(cuid())
  name                   String
  assetClass             AssetClass
  capitalInstrument      CapitalInstrument?
  participationStructure ParticipationStructure?
  sector                 String?
  status                 AssetStatus           @default(ACTIVE)
  costBasis              Float
  fairValue   Float
  moic        Float?
  irr         Float?
  incomeType  String?
  hasBoardSeat Boolean    @default(false)
  entryDate   DateTime?
  sourceDealId String?    // Links back to the originating deal
  nextReview  DateTime?

  // Phase 4: Performance attribution projections
  projectedIRR      Float?   // From deal screening / GP override
  projectedMultiple Float?   // Target MOIC/multiple
  projectedMetrics  Json?    // Asset-class-specific: { capRate, cashOnCash, yieldToMaturity, ... }

  // Phase 14: Exit workflow fields
  exitDate         DateTime?
  exitProceeds     Float?
  exitNotes        String?

  // Phase 14: Ownership tracking
  ownershipPercent Float?    // % of underlying asset owned (e.g., 12%)
  shareCount       Float?    // Shares/units held (e.g., 500000 shares)

  // Phase 14: Review schedule
  reviewFrequency  String?   // "quarterly" | "semi_annual" | "annual"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sourceDeal         Deal?                 @relation("AssetSourceDeal", fields: [sourceDealId], references: [id])
  entityAllocations  AssetEntityAllocation[]
  equityDetails      AssetEquityDetails?
  creditDetails      AssetCreditDetails?
  realEstateDetails  AssetRealEstateDetails?
  fundLPDetails      AssetFundLPDetails?
  leases             Lease[]
  creditAgreements   CreditAgreement[]
  valuations         Valuation[]
  tasks              Task[]
  documents          Document[]
  meetings           Meeting[]
  incomeEvents       IncomeEvent[]
  expenses           AssetExpense[]
  activityEvents     ActivityEvent[]
  notes              Note[]
  savedConversations SavedConversation[]

  @@index([assetClass])
  @@index([status])
  // Note: Asset has no direct firmId — queried via entityAllocations.entity.firmId
}

model AssetEntityAllocation {
  id                String @id @default(cuid())
  assetId           String
  entityId          String
  allocationPercent Float  @default(100)
  costBasis         Float?
  status            String @default("active")
  createdAt         DateTime @default(now())

  asset  Asset  @relation(fields: [assetId], references: [id])
  entity Entity @relation(fields: [entityId], references: [id])

  @@unique([assetId, entityId])
}

model AssetEquityDetails {
  id         String @id @default(cuid())
  assetId    String @unique
  instrument String?
  ownership  String?
  revenue    String?
  ebitda     String?
  growth     String?
  employees  Int?

  asset Asset @relation(fields: [assetId], references: [id])
}

model AssetCreditDetails {
  id              String @id @default(cuid())
  assetId         String @unique
  instrument      String?
  principal       String?
  rate            String?
  maturity        String?
  ltv             String?
  dscr            String?
  nextPaymentDate String?
  accruedInterest String?

  asset Asset @relation(fields: [assetId], references: [id])
}

model AssetRealEstateDetails {
  id           String @id @default(cuid())
  assetId      String @unique
  propertyType String?
  squareFeet   String?
  occupancy    String?
  noi          String?
  capRate      String?
  rentPerSqft  String?
  debt         String?
  debtDscr     String?

  asset Asset @relation(fields: [assetId], references: [id])
}

model AssetFundLPDetails {
  id             String @id @default(cuid())
  assetId        String @unique
  gpName         String?
  commitment     String?
  calledAmount   String?
  uncalledAmount String?
  distributions  String?
  gpNav          String?
  navDate        String?
  gpIrr          String?
  gpTvpi         String?
  vintage        Int?
  strategy       String?

  asset Asset @relation(fields: [assetId], references: [id])
}

// ============================================================
// CONTRACT-LEVEL: Leases, Credit Agreements, Covenants
// ============================================================

model Lease {
  id                       String      @id @default(cuid())
  assetId                  String
  tenantName               String
  tenantEntity             String?
  unitOrSuite              String?
  squareFootage            String?
  leaseType                LeaseType   @default(NNN)
  baseRentMonthly          Float?
  baseRentAnnual           Float?
  rentEscalation           Json?
  camCharges               Float?
  taxPassThrough           Float?
  insurancePassThrough     Float?
  leaseStartDate           DateTime?
  leaseEndDate             DateTime?
  renewalOptions           Json?
  terminationOptions       Json?
  securityDeposit          Float?
  freeRentMonths           Int?
  tenantImprovementAllowance Float?
  currentStatus            LeaseStatus @default(ACTIVE)
  rentPercentOfTotal       String?
  notes                    String?
  createdAt                DateTime    @default(now())
  updatedAt                DateTime    @updatedAt

  asset Asset @relation(fields: [assetId], references: [id])
}

model CreditAgreement {
  id                    String              @id @default(cuid())
  assetId               String
  borrowerName          String
  borrowerEntity        String?
  agreementType         CreditAgreementType @default(LOAN_AGREEMENT)
  originalPrincipal     Float
  currentPrincipal      Float
  commitmentAmount      Float?
  drawnAmount           Float?
  interestRateType      InterestRateType    @default(FIXED)
  fixedRate             Float?
  referenceRate         String?
  spreadBps             Int?
  pikRate               Float?
  floorRate             Float?
  dayCount              DayCount            @default(ACTUAL_360)
  paymentFrequency      PaymentFrequency    @default(MONTHLY)
  paymentDay            Int?
  amortization          String?
  amortizationSchedule  Json?
  maturityDate          DateTime?
  prepaymentTerms       Json?
  collateral            Json?
  guarantors            Json?
  subordination         Subordination       @default(SENIOR)
  intercreditorAgreement Boolean            @default(false)
  defaultProvisions     Json?
  currentStatus         CreditStatus        @default(PERFORMING)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  asset     Asset      @relation(fields: [assetId], references: [id])
  covenants Covenant[]
  payments  CreditPayment[]
}

model Covenant {
  id                  String         @id @default(cuid())
  agreementId         String
  name                String
  covenantType        CovenantType   @default(FINANCIAL)
  metric              String?
  thresholdOperator   String?
  thresholdValue      Float?
  thresholdValueUpper Float?
  testFrequency       String?
  curePeriodDays      Int?
  lastTestedDate      DateTime?
  lastTestedValue     String?
  currentStatus       CovenantStatus @default(COMPLIANT)
  breachHistory       Json?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  agreement CreditAgreement @relation(fields: [agreementId], references: [id])
}

model CreditPayment {
  id          String   @id @default(cuid())
  agreementId String
  date        DateTime
  paymentType String
  amount      Float
  status      String   @default("Received")
  createdAt   DateTime @default(now())

  agreement CreditAgreement @relation(fields: [agreementId], references: [id])
}

// ============================================================
// INVESTORS
// ============================================================

model Investor {
  id               String  @id @default(cuid())
  contactId        String? @unique
  companyId        String? @unique
  name             String
  investorType     String
  kycStatus        String  @default("Pending")
  advisoryBoard    Boolean @default(false)
  contactPreference String @default("email")
  totalCommitted   Float   @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  mailingAddress  String?
  taxId           String?
  phone           String?

  contact                Contact?                    @relation(fields: [contactId], references: [id])
  company                Company?                    @relation(fields: [companyId], references: [id])
  userAccess             InvestorUserAccess[]
  commitments            Commitment[]
  sideLetters            SideLetter[]
  notificationPreference InvestorNotificationPreference?
  capitalCallLineItems   CapitalCallLineItem[]
  distributionLineItems  DistributionLineItem[]
  capitalAccounts        CapitalAccount[]
  documents              Document[]
  notes                  Note[]
  metricSnapshots        MetricSnapshot[]
  savedConversations     SavedConversation[]
  ownershipUnits         OwnershipUnit[]
  dwollaCustomer         InvestorDwollaCustomer?
  paymentMethods         InvestorPaymentMethod[]
}

model Commitment {
  id          String   @id @default(cuid())
  investorId  String
  entityId    String
  amount      Float
  calledAmount Float   @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  investor Investor @relation(fields: [investorId], references: [id])
  entity   Entity   @relation(fields: [entityId], references: [id])

  @@unique([investorId, entityId])
}

model UnitClass {
  id                  String          @id @default(cuid())
  entityId            String
  name                String
  classType           UnitClassType   @default(LP_UNIT)
  description         String?
  unitPrice           Float           @default(1000)
  totalAuthorized     Float?
  totalIssued         Float           @default(0)
  preferredReturnRate Float?
  managementFeeRate   Float?
  votingRights        Boolean         @default(true)
  status              UnitClassStatus @default(ACTIVE)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  entity         Entity          @relation(fields: [entityId], references: [id], onDelete: Cascade)
  ownershipUnits OwnershipUnit[]

  @@unique([entityId, name])
  @@index([entityId])
}

model OwnershipUnit {
  id              String              @id @default(cuid())
  unitClassId     String
  investorId      String
  unitsIssued     Float
  unitCost        Float
  acquisitionDate DateTime
  status          OwnershipUnitStatus @default(ACTIVE)
  notes           String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  unitClass UnitClass @relation(fields: [unitClassId], references: [id], onDelete: Cascade)
  investor  Investor  @relation(fields: [investorId], references: [id])

  @@index([unitClassId])
  @@index([investorId])
}

model SideLetter {
  id         String   @id @default(cuid())
  investorId String
  entityId   String
  terms      String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  investor Investor           @relation(fields: [investorId], references: [id])
  entity   Entity             @relation(fields: [entityId], references: [id])
  rules    SideLetterRule[]
}

model SideLetterRule {
  id           String             @id @default(cuid())
  sideLetterId String
  ruleType     SideLetterRuleType
  value        Float?
  description  String?
  isActive     Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  sideLetter   SideLetter         @relation(fields: [sideLetterId], references: [id], onDelete: Cascade)
}

model InvestorNotificationPreference {
  id                String              @id @default(cuid())
  investorId        String              @unique
  preferredChannel  NotificationChannel @default(EMAIL)
  emailAddress      String?
  phoneNumber       String?
  notificationTypes Json?
  digestPreference  DigestPreference    @default(IMMEDIATE)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  investor Investor @relation(fields: [investorId], references: [id])
}

// ============================================================
// TRANSACTIONS
// ============================================================

model Transaction {
  id              String          @id @default(cuid())
  entityId        String
  transactionType TransactionType
  amount          Float
  date            DateTime
  description     String?
  isPrincipal     Boolean         @default(false)
  referenceId     String?
  referenceType   String?
  createdAt       DateTime        @default(now())

  entity Entity @relation(fields: [entityId], references: [id])
}

model CapitalCall {
  id         String            @id @default(cuid())
  entityId   String
  callNumber String
  callDate   DateTime
  dueDate    DateTime
  amount     Float
  purpose    String?
  status     CapitalCallStatus @default(DRAFT)
  fundedPercent Float          @default(0)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  entity    Entity              @relation(fields: [entityId], references: [id])
  lineItems CapitalCallLineItem[]
  documents Document[]

  // Optimizes: GET /api/capital-calls?status=OVERDUE (overdue call queries filter by status)
  @@index([status])
  // Optimizes: GET /api/capital-calls?entityId=xxx&status=ISSUED (entity-scoped status queries)
  @@index([entityId, status])
}

model CapitalCallLineItem {
  id            String   @id @default(cuid())
  capitalCallId String
  investorId    String
  amount        Float
  status        String   @default("Pending")
  paidDate      DateTime?
  createdAt     DateTime @default(now())

  // Phase A: payment rail tracking
  paymentMethod       PaymentMethod? // DWOLLA_ACH | EXTERNAL_WIRE | EXTERNAL_CHECK | EXTERNAL_OTHER
  paymentStatus       PaymentStatus? // PENDING | PROCESSED | COMPLETED | FAILED | CANCELLED
  dwollaTransferId    String?        // Dwolla transfer URL id for webhook lookup
  paymentInitiatedAt  DateTime?
  paymentCompletedAt  DateTime?
  failureReason       String?
  externalReference   String?        // Wire reference, check #, etc. when paid outside portal

  capitalCall CapitalCall @relation(fields: [capitalCallId], references: [id])
  investor    Investor    @relation(fields: [investorId], references: [id])

  @@index([dwollaTransferId])
  @@index([paymentStatus])
}

model DistributionEvent {
  id                String             @id @default(cuid())
  entityId          String
  distributionDate  DateTime
  grossAmount       Float
  source            String?
  returnOfCapital   Float              @default(0)
  income            Float              @default(0)
  longTermGain      Float              @default(0)
  shortTermGain     Float              @default(0)
  carriedInterest   Float              @default(0)
  netToLPs          Float              @default(0)
  status            DistributionStatus @default(DRAFT)

  // Phase 3: Distribution type and memo
  distributionType          String?  // "INCOME" | "RETURN_OF_CAPITAL" | "CAPITAL_GAIN" | "FINAL_LIQUIDATION"
  memo                      String?
  waterfallCalculationId    String?  // Optional link to the waterfall calc that produced this distribution

  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  entity    Entity                 @relation(fields: [entityId], references: [id])
  lineItems DistributionLineItem[]
  documents Document[]
}

model DistributionLineItem {
  id               String   @id @default(cuid())
  distributionId   String
  investorId       String
  grossAmount      Float
  returnOfCapital  Float    @default(0)
  income           Float    @default(0)
  longTermGain     Float    @default(0)
  carriedInterest  Float    @default(0)
  netAmount        Float

  // Phase 3: Distribution type carried through to line items
  distributionType String?

  // Phase A: payment rail tracking
  paymentMethod       PaymentMethod? // DWOLLA_ACH | EXTERNAL_WIRE | EXTERNAL_CHECK | EXTERNAL_OTHER
  paymentStatus       PaymentStatus? // PENDING | PROCESSED | COMPLETED | FAILED | CANCELLED
  dwollaTransferId    String?        // Dwolla transfer URL id for webhook lookup
  paymentInitiatedAt  DateTime?
  paymentCompletedAt  DateTime?
  failureReason       String?
  externalReference   String?        // Wire reference, check #, etc. when paid outside portal

  createdAt        DateTime @default(now())

  distribution DistributionEvent @relation(fields: [distributionId], references: [id])
  investor     Investor          @relation(fields: [investorId], references: [id])

  @@index([dwollaTransferId])
  @@index([paymentStatus])
}

model IncomeEvent {
  id          String     @id @default(cuid())
  assetId     String?
  entityId    String
  incomeType  IncomeType
  amount      Float
  date        DateTime
  description String?
  isPrincipal Boolean    @default(false)
  createdAt   DateTime   @default(now())

  asset  Asset?  @relation(fields: [assetId], references: [id])
  entity Entity  @relation(fields: [entityId], references: [id])
}

model AssetExpense {
  id          String   @id @default(cuid())
  assetId     String
  entityId    String
  category    String   // "management_fee", "legal", "maintenance", "insurance", "taxes", "other"
  amount      Float
  date        DateTime
  description String?
  createdAt   DateTime @default(now())

  asset  Asset  @relation(fields: [assetId], references: [id])
  entity Entity @relation(fields: [entityId], references: [id])
}

// ============================================================
// VALUATIONS & NAV
// ============================================================

model Valuation {
  id              String          @id @default(cuid())
  assetId         String
  valuationDate   DateTime
  method          ValuationMethod
  fairValue       Float
  moic            Float?
  notes           String?
  status          ValuationStatus @default(DRAFT)
  approvedBy      String?
  approvedAt      DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  asset Asset @relation(fields: [assetId], references: [id])

  @@index([assetId, valuationDate])
}

model NAVComputation {
  id            String   @id @default(cuid())
  entityId      String
  periodDate    DateTime
  costBasisNAV  Float
  economicNAV   Float
  unrealizedGain Float?
  accruedCarry  Float?
  details       Json?
  createdAt     DateTime @default(now())

  entity Entity @relation(fields: [entityId], references: [id])

  @@unique([entityId, periodDate])
}

// ============================================================
// FUND MECHANICS: Waterfall, Fees, Capital Accounts
// ============================================================

model WaterfallTemplate {
  id          String  @id @default(cuid())
  name        String
  description String?

  // Phase 3: Fee configuration fields
  managementFeeRate              Float?   // Annual rate as decimal (e.g., 0.02 = 2%)
  feeBasis                       String?  // "COMMITTED_CAPITAL" | "INVESTED_CAPITAL" | "NAV"
  carryPercent                   Float?   // Carried interest % (e.g., 0.20 = 20%)
  prefReturnRate                 Float?   // Preferred return rate if different from hurdle
  prefReturnCompounding          String?  // "SIMPLE" | "COMPOUND"
  prefReturnOffsetByDistributions Boolean @default(false)
  incomeCountsTowardPref         Boolean  @default(false)
  gpCoInvestPercent              Float?   // GP co-investment % (null = no GP co-invest)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tiers         WaterfallTier[]
  entities      Entity[]        @relation("EntityWaterfall")
  calculations  WaterfallCalculation[]
}

model WaterfallTier {
  id                String  @id @default(cuid())
  templateId        String
  tierOrder         Int
  name              String
  description       String?
  splitLP           Float?
  splitGP           Float?
  hurdleRate        Float?
  appliesTo         String?
  createdAt         DateTime @default(now())

  template WaterfallTemplate @relation(fields: [templateId], references: [id])

  @@index([templateId, tierOrder])
}

model WaterfallCalculation {
  id          String   @id @default(cuid())
  templateId  String
  periodDate  DateTime
  results     Json
  createdAt   DateTime @default(now())

  template WaterfallTemplate @relation(fields: [templateId], references: [id])
}

model FeeCalculation {
  id              String   @id @default(cuid())
  entityId        String
  periodDate      DateTime
  managementFee   Float    @default(0)
  fundExpenses    Float    @default(0)
  carriedInterest Float    @default(0)
  details         Json?
  createdAt       DateTime @default(now())

  entity Entity @relation(fields: [entityId], references: [id])
}

model CapitalAccount {
  id               String   @id @default(cuid())
  investorId       String
  entityId         String
  periodDate       DateTime
  beginningBalance Float
  contributions    Float    @default(0)
  incomeAllocations Float   @default(0)
  capitalAllocations Float  @default(0)
  distributions    Float    @default(0)
  fees             Float    @default(0)
  endingBalance    Float
  details          Json?
  createdAt        DateTime @default(now())

  investor Investor @relation(fields: [investorId], references: [id])
  entity   Entity   @relation(fields: [entityId], references: [id])

  @@unique([investorId, entityId, periodDate])
}

// ============================================================
// DEAL DESK
// ============================================================

model Deal {
  id                     String                 @id @default(cuid())
  firmId                 String?
  name                   String
  assetClass             AssetClass
  capitalInstrument      CapitalInstrument?
  participationStructure ParticipationStructure?
  sector                 String?
  stage                  DealStage              @default(SCREENING)
  targetSize             String?
  dealLeadId             String?
  aiScore                Int?
  aiFlag         String?
  source         String?
  counterparty   String?
  entityId       String?
  description         String?
  thesisNotes         String?
  aiPromptConfig      Json?
  targetCheckSize     String?
  targetReturn        String?
  gpName              String?
  investmentRationale String?
  additionalContext   String?

  // Kill/Revive fields
  killReason     String?      // Pricing, Risk, Timing, Sponsor, Other
  killReasonText String?      // Free text explanation
  previousStage  DealStage?   // Stage before kill (for revive)
  dealMetadata   Json?        // AI-extracted structured data (size, target return, terms, structure)

  // Deadline tracking
  nextDeadline      DateTime?
  nextDeadlineLabel String?    // e.g., "Exclusivity expires", "IC Meeting"

  // Investment horizon
  projectedExitTimeframe String?  // e.g., "3-5 years", "2028", "7+ years"

  // CRM sourcing attribution
  sourcedByContactId  String?
  sourcedByContact    Contact? @relation("DealSourceContact", fields: [sourcedByContactId], references: [id])

  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  firm             Firm?              @relation(fields: [firmId], references: [id])
  dealLead         User?              @relation("DealLead", fields: [dealLeadId], references: [id])
  targetEntity     Entity?            @relation("DealTargetEntity", fields: [entityId], references: [id])
  icProcess        ICProcess?
  workstreams      DDWorkstream[]
  screeningResult  AIScreeningResult?
  closingChecklist ClosingChecklist[]
  icQuestions      ICQuestion[]
  documents          Document[]
  meetings           Meeting[]
  notes              Note[]
  esignaturePackages ESignaturePackage[]
  activities         DealActivity[]
  tasks              Task[]
  dealEntities       DealEntity[]
  sourceAssets       Asset[]        @relation("AssetSourceDeal")
  contactInteractions ContactInteraction[] @relation("DealContactInteractions")
  coInvestors         DealCoInvestor[]
  savedConversations  SavedConversation[]

  @@index([stage])
  @@index([firmId])
  @@index([sourcedByContactId])
  // Optimizes: GET /api/deals?firmId=xxx&stage=SCREENING (common pipeline query pattern)
  @@index([firmId, stage])
}

model ICProcess {
  id             String   @id @default(cuid())
  dealId         String   @unique
  slackMessageId String?
  slackChannel   String?
  quorumType     String   @default("majority")
  deadline       DateTime?
  status         String   @default("pending")
  finalDecision  String?
  decidedById    String?
  decidedAt      DateTime?
  decisionNotes  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  deal      Deal          @relation(fields: [dealId], references: [id])
  votes     ICVoteRecord[]
  decidedBy User?         @relation("ICDecisions", fields: [decidedById], references: [id])
}

model ICVoteRecord {
  id          String   @id @default(cuid())
  icProcessId String
  userId      String
  vote        String
  votedAt     DateTime @default(now())
  notes       String?
  conditions  String?  // Text note for conditional votes (e.g., "contingent on side letter review")

  icProcess ICProcess @relation(fields: [icProcessId], references: [id])
  user      User      @relation(fields: [userId], references: [id])
}

model DDWorkstream {
  id                 String             @id @default(cuid())
  dealId             String
  name               String
  status             DDWorkstreamStatus @default(NOT_STARTED)
  totalTasks         Int                @default(0)
  completedTasks     Int                @default(0)
  hasAI              Boolean            @default(false)
  description        String?
  customInstructions String?
  aiGenerated        Boolean            @default(false)
  sortOrder          Int                @default(0)
  analysisType       String?            // e.g. "DD_FINANCIAL", "DD_LEGAL", "IC_MEMO"
  analysisResult     Json?              // Full AI analysis output (summary, sections, recommendation)

  // PM enhancements
  assigneeId         String?
  priority           String?            @default("MEDIUM") // High/Medium/Low
  dueDate            DateTime?

  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  deal        Deal                    @relation(fields: [dealId], references: [id])
  tasks       DDTask[]
  assignee    User?                   @relation("WorkstreamAssignee", fields: [assigneeId], references: [id])
  comments    DDWorkstreamComment[]
  attachments DDWorkstreamAttachment[]
}

model DDTask {
  id           String     @id @default(cuid())
  workstreamId String
  title        String
  status       TaskStatus @default(TODO)
  assignee     String?
  dueDate      DateTime?
  notes        String?
  description  String?
  priority     String?
  source       String?
  resolution   String?
  resolvedAt   DateTime?
  resolvedBy   String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  workstream  DDWorkstream       @relation(fields: [workstreamId], references: [id])
  comments    DDTaskComment[]
  attachments DDTaskAttachment[]
}

model DDTaskComment {
  id        String   @id @default(cuid())
  taskId    String
  authorId  String
  content   String
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task    DDTask          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author  User            @relation("TaskCommentAuthor", fields: [authorId], references: [id])
  parent  DDTaskComment?  @relation("TaskCommentThread", fields: [parentId], references: [id])
  replies DDTaskComment[] @relation("TaskCommentThread")

  @@index([taskId])
}

model DDTaskAttachment {
  id           String   @id @default(cuid())
  taskId       String
  fileName     String
  fileUrl      String
  fileSize     Int?
  uploadedById String?
  createdAt    DateTime @default(now())

  task DDTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model AIScreeningResult {
  id               String    @id @default(cuid())
  dealId           String    @unique
  score            Int?
  summary          String?
  strengths        Json?
  risks            Json?
  financials       Json?
  recommendation   String?
  ddFindings       Json?
  inputContext      Json?
  screeningConfig  Json?
  processedAt      DateTime  @default(now())
  version          Int       @default(1)
  memo             Json?     // IC Memo: { summary, sections[], recommendation }
  memoGeneratedAt  DateTime?
  previousVersions Json?     // Array of full snapshots for version history

  deal Deal @relation(fields: [dealId], references: [id])
}

model ICQuestion {
  id        String           @id @default(cuid())
  dealId    String
  authorId  String
  content   String
  status    ICQuestionStatus @default(OPEN)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  deal    Deal              @relation(fields: [dealId], references: [id])
  author  User              @relation("ICQuestionAuthor", fields: [authorId], references: [id])
  replies ICQuestionReply[]

  @@index([dealId])
}

model ICQuestionReply {
  id         String   @id @default(cuid())
  questionId String
  authorId   String
  content    String
  createdAt  DateTime @default(now())

  question ICQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  author   User       @relation("ICQuestionReplyAuthor", fields: [authorId], references: [id])

  @@index([questionId])
}

model ClosingChecklist {
  id         String                @id @default(cuid())
  dealId     String
  title      String
  status     ClosingChecklistStatus @default(NOT_STARTED)
  assigneeId String?
  assignee   String?
  dueDate    DateTime?
  notes      String?
  order      Int                   @default(0)
  fileUrl    String?               // Vercel Blob URL for attached file
  fileName   String?               // Display name of attached file
  isCustom   Boolean               @default(false) // Distinguishes template vs custom items
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  deal       Deal  @relation(fields: [dealId], references: [id])
  assignedTo User? @relation("ClosingAssignments", fields: [assigneeId], references: [id])
}

model DealActivity {
  id           String   @id @default(cuid())
  dealId       String
  activityType String
  description  String
  metadata     Json?
  createdAt    DateTime @default(now())

  deal Deal @relation(fields: [dealId], references: [id])

  @@index([dealId])
  // Optimizes: activity feed queries filtering by type (e.g. STAGE events for daysInStage computation)
  @@index([dealId, activityType])
}

model DealEntity {
  id                String   @id @default(cuid())
  dealId            String
  entityId          String
  allocationPercent Float?
  role              String?  // "Lead Entity", "Co-Investor"
  createdAt         DateTime @default(now())

  deal   Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)
  entity Entity @relation(fields: [entityId], references: [id])

  @@unique([dealId, entityId])
  @@index([dealId])
  @@index([entityId])
}

model DDWorkstreamComment {
  id           String   @id @default(cuid())
  workstreamId String
  authorId     String
  content      String
  parentId     String?  // for threading
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workstream DDWorkstream        @relation(fields: [workstreamId], references: [id], onDelete: Cascade)
  author     User                @relation("WorkstreamCommentAuthor", fields: [authorId], references: [id])
  parent     DDWorkstreamComment?  @relation("CommentThread", fields: [parentId], references: [id])
  replies    DDWorkstreamComment[] @relation("CommentThread")

  @@index([workstreamId])
}

model DDWorkstreamAttachment {
  id           String   @id @default(cuid())
  workstreamId String
  fileName     String
  fileUrl      String
  fileSize     Int?
  uploadedById String?
  createdAt    DateTime @default(now())

  workstream DDWorkstream @relation(fields: [workstreamId], references: [id], onDelete: Cascade)

  @@index([workstreamId])
}

model DecisionStructure {
  id                String   @id @default(cuid())
  firmId            String
  name              String
  description       String?
  quorumRequired    Int      @default(1)
  approvalThreshold Int      @default(1)  // votes needed for approval
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  firm     Firm               @relation(fields: [firmId], references: [id])
  members  DecisionMember[]
  entities Entity[]           @relation("EntityDecisionStructure")

  @@index([firmId])
}

model DecisionMember {
  id          String   @id @default(cuid())
  structureId String
  userId      String
  role        String?  @default("VOTER")  // VOTER, OBSERVER
  createdAt   DateTime @default(now())

  structure DecisionStructure @relation(fields: [structureId], references: [id], onDelete: Cascade)
  user      User              @relation(fields: [userId], references: [id])

  @@unique([structureId, userId])
}

model DDCategoryTemplate {
  id                  String   @id @default(cuid())
  firmId              String?
  name                String
  description         String?
  defaultInstructions String?
  isDefault           Boolean  @default(true)
  scope               String   @default("UNIVERSAL")
  sortOrder           Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  firm Firm? @relation(fields: [firmId], references: [id])
}

model Note {
  id         String   @id @default(cuid())
  content    String
  authorId   String?
  assetId    String?
  dealId     String?
  entityId   String?
  investorId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  author   User?     @relation(fields: [authorId], references: [id])
  asset    Asset?    @relation(fields: [assetId], references: [id])
  deal     Deal?     @relation(fields: [dealId], references: [id])
  entity   Entity?   @relation(fields: [entityId], references: [id])
  investor Investor? @relation(fields: [investorId], references: [id])
}

model SavedConversation {
  id         String   @id @default(cuid())
  title      String
  messages   Json     // [{ role, content, timestamp }]
  summary    String?
  dealId     String?
  assetId    String?
  entityId   String?
  investorId String?
  authorId   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  deal     Deal?     @relation(fields: [dealId], references: [id])
  asset    Asset?    @relation(fields: [assetId], references: [id])
  entity   Entity?   @relation(fields: [entityId], references: [id])
  investor Investor? @relation(fields: [investorId], references: [id])
  author   User      @relation("UserSavedConversations", fields: [authorId], references: [id])

  @@index([dealId])
  @@index([assetId])
  @@index([entityId])
  @@index([investorId])
}

// ============================================================
// TASKS & MEETINGS
// ============================================================

model Task {
  id           String     @id @default(cuid())
  title        String
  description  String?
  status       TaskStatus @default(TODO)
  priority     String?    @default("MEDIUM")
  assigneeId   String?
  assigneeName String?
  dueDate      DateTime?
  notes        String?
  order        Int?
  contextType  String?
  contextId    String?
  assetId      String?
  dealId       String?
  entityId     String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  assignee       User?                @relation(fields: [assigneeId], references: [id])
  asset          Asset?               @relation(fields: [assetId], references: [id])
  deal           Deal?                @relation(fields: [dealId], references: [id])
  entity         Entity?              @relation(fields: [entityId], references: [id])
  checklistItems TaskChecklistItem[]

  @@index([contextType, contextId])
  @@index([dealId])
  @@index([entityId])
  @@index([assigneeId])
  // Optimizes: GET /api/tasks?assetId=xxx (asset-scoped task queries)
  @@index([assetId])
}

model TaskChecklistItem {
  id         String   @id @default(cuid())
  taskId     String
  title      String
  isChecked  Boolean  @default(false)
  position   Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model Meeting {
  id            String        @id @default(cuid())
  title         String
  meetingDate   DateTime
  meetingType   String?
  source        MeetingSource @default(MANUAL)
  hasTranscript Boolean       @default(false)
  actionItems   Int           @default(0)
  decisions     Json?
  assetId       String?
  dealId        String?
  entityId      String?
  transcript    String?
  summary       String?
  firefliesId   String?  @unique
  firmId        String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  asset  Asset?  @relation(fields: [assetId], references: [id])
  deal   Deal?   @relation(fields: [dealId], references: [id])
  entity Entity? @relation(fields: [entityId], references: [id])

  // Optimizes: GET /api/meetings?firmId=xxx (firm-scoped meeting list queries)
  @@index([firmId])
  // Optimizes: GET /api/meetings?entityId=xxx (entity-scoped meeting queries)
  @@index([entityId])
}

model Document {
  id          String           @id @default(cuid())
  name        String
  category    DocumentCategory @default(OTHER)
  fileUrl     String?
  fileSize      Int?
  mimeType      String?
  extractedText String?
  // AI extraction pipeline fields
  extractionStatus ExtractionStatus @default(NONE)
  extractedFields  Json?    // Raw AI output: { fieldKey: { aiValue, label } }[]
  appliedFields    Json?    // Audit record: { fieldKey: { aiValue, appliedValue, appliedAt } }[]
  extractionError  String?  // Error message if FAILED
  assetId             String?
  entityId            String?
  dealId              String?
  investorId          String?
  capitalCallId       String?
  distributionEventId String?
  uploadDate  DateTime         @default(now())
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  acknowledgedAt          DateTime?
  acknowledgedByInvestorId String?

  asset             Asset?             @relation(fields: [assetId], references: [id])
  entity            Entity?            @relation(fields: [entityId], references: [id])
  deal              Deal?              @relation(fields: [dealId], references: [id])
  investor          Investor?          @relation(fields: [investorId], references: [id])
  capitalCall       CapitalCall?       @relation(fields: [capitalCallId], references: [id])
  distributionEvent DistributionEvent? @relation(fields: [distributionEventId], references: [id])

  // Note: Document has no direct firmId — queried via entity.firmId or deal.firmId
  // Optimizes: GET /api/documents?entityId=xxx (entity-scoped document queries)
  @@index([entityId])
  // Optimizes: GET /api/documents?dealId=xxx (deal-scoped document queries)
  @@index([dealId])
  // Optimizes: document extraction pipeline queries filtering by status
  @@index([extractionStatus])
}

model Notification {
  id          String              @id @default(cuid())
  investorId  String?
  userId      String?
  channel     NotificationChannel @default(EMAIL)
  type        NotificationType    @default(GENERAL)
  subject     String
  body        String?
  isRead      Boolean             @default(false)
  readAt      DateTime?
  sentAt      DateTime?
  status      String              @default("pending")
  createdAt   DateTime            @default(now())

  user        User?               @relation("UserNotifications", fields: [userId], references: [id])
}

model ActivityEvent {
  id          String   @id @default(cuid())
  assetId     String?
  description String
  eventDate   DateTime
  eventType   String
  createdAt   DateTime @default(now())

  asset Asset? @relation(fields: [assetId], references: [id])
}

// ============================================================
// E-SIGNATURE
// ============================================================

enum ESignatureStatus {
  DRAFT
  SENT
  VIEWED
  PARTIALLY_SIGNED
  COMPLETED
  DECLINED
  EXPIRED
}

model ESignaturePackage {
  id          String           @id @default(cuid())
  title       String
  status      ESignatureStatus @default(DRAFT)
  provider    String           @default("docusign")
  externalId  String?
  entityId    String?
  dealId      String?
  documentId  String?
  signers     Json?
  sentAt      DateTime?
  completedAt DateTime?
  expiresAt   DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  entity   Entity?   @relation(fields: [entityId], references: [id])
  deal     Deal?     @relation(fields: [dealId], references: [id])

  @@index([entityId])
  @@index([dealId])
  @@index([status])
}

// ============================================================
// DOCUSIGN INTEGRATION
// ============================================================

model DocuSignConnection {
  id           String   @id @default(cuid())
  firmId       String   @unique
  accessToken  String
  refreshToken String
  tokenExpiry  DateTime
  accountId    String   // DocuSign account ID
  baseUri      String   // API base URI from /oauth/userinfo
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ============================================================
// FUNDRAISING
// ============================================================

enum FundraisingRoundStatus {
  PLANNING
  OPEN
  FINAL_CLOSE
  CLOSED
}

enum UnitClassType {
  LP_UNIT
  GP_UNIT
  CARRIED_INTEREST
  MANAGEMENT
}

enum UnitClassStatus {
  ACTIVE
  FROZEN
  RETIRED
}

enum OwnershipUnitStatus {
  ACTIVE
  REDEEMED
  TRANSFERRED
  CANCELLED
}

enum ProspectStatus {
  IDENTIFIED
  CONTACTED
  MEETING_SCHEDULED
  DD_IN_PROGRESS
  TERM_SHEET_SENT
  SOFT_COMMIT
  HARD_COMMIT
  DECLINED
  WITHDRAWN
}

model FundraisingRound {
  id            String                  @id @default(cuid())
  entityId      String
  name          String
  targetAmount  Float?
  raisedAmount  Float                   @default(0)
  status        FundraisingRoundStatus  @default(PLANNING)
  openDate      DateTime?
  closeDate     DateTime?
  notes         String?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  entity    Entity                @relation(fields: [entityId], references: [id])
  prospects FundraisingProspect[]

  @@index([entityId])
  @@index([status])
}

model FundraisingProspect {
  id              String          @id @default(cuid())
  roundId         String
  investorName    String
  investorType    String?
  contactName     String?
  contactEmail    String?
  targetAmount    Float?
  softCommitAmount Float?
  hardCommitAmount Float?
  status          ProspectStatus  @default(IDENTIFIED)
  lastContactDate DateTime?
  nextFollowUp    DateTime?
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  round FundraisingRound @relation(fields: [roundId], references: [id])

  @@index([roundId])
  @@index([status])
}

// ============================================================
// CRM: Companies & Contacts
// ============================================================

model Company {
  id              String      @id @default(cuid())
  firmId          String
  firm            Firm        @relation(fields: [firmId], references: [id])
  name            String
  legalName       String?
  type            CompanyType @default(OTHER)
  website         String?
  industry        String?
  address         String?
  notes           String?
  contacts        Contact[]
  investorProfile Investor?
  coinvestments   DealCoInvestor[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([firmId])
}

model Contact {
  id              String      @id @default(cuid())
  firmId          String
  firm            Firm        @relation(fields: [firmId], references: [id])
  firstName       String
  lastName        String
  email           String?
  phone           String?
  title           String?
  type            ContactType @default(EXTERNAL)
  companyId       String?
  company         Company?    @relation(fields: [companyId], references: [id])
  investorProfile Investor?
  userAccount     User?
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  interactions    ContactInteraction[]
  tags            ContactTag[]
  sourcedDeals    Deal[]            @relation("DealSourceContact")
  coinvestments   DealCoInvestor[]

  @@index([firmId])
  @@index([companyId])
}

model ContactInteraction {
  id        String   @id @default(cuid())
  firmId    String
  contactId String
  authorId  String
  type      String   // CALL, EMAIL, MEETING, NOTE
  notes     String
  date      DateTime @default(now())
  dealId    String?
  entityId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  firm      Firm     @relation("FirmContactInteractions", fields: [firmId], references: [id])
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  author    User     @relation("UserContactInteractions", fields: [authorId], references: [id])
  deal      Deal?    @relation("DealContactInteractions", fields: [dealId], references: [id])
  entity    Entity?  @relation("EntityContactInteractions", fields: [entityId], references: [id])

  @@index([contactId])
  @@index([firmId])
  @@index([authorId])
}

model ContactTag {
  id        String  @id @default(cuid())
  firmId    String
  contactId String
  tag       String

  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  firm      Firm    @relation("FirmContactTags", fields: [firmId], references: [id])

  @@unique([contactId, tag])
  @@index([firmId])
}

model DealCoInvestor {
  id          String   @id @default(cuid())
  dealId      String
  contactId   String?
  companyId   String?
  role        String   // "Lead", "Participant", "Syndicate Member"
  allocation  Float?
  status      String   // "Interested", "Committed", "Funded", "Passed"
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  deal        Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  contact     Contact? @relation(fields: [contactId], references: [id])
  company     Company? @relation(fields: [companyId], references: [id])

  @@index([dealId])
  @@index([contactId])
  @@index([companyId])
}

// ============================================================
// INVESTOR USER ACCESS (many-to-many)
// ============================================================

model InvestorUserAccess {
  id          String   @id @default(cuid())
  investorId  String
  userId      String
  role        String   @default("viewer")  // "primary", "viewer", "admin"
  createdAt   DateTime @default(now())

  investor    Investor @relation(fields: [investorId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([investorId, userId])
  @@index([userId])
  @@index([investorId])
}

// ============================================================
// AUDIT LOG
// ============================================================

model AuditLog {
  id         String   @id @default(cuid())
  firmId     String
  userId     String
  action     String   // e.g. "CREATE_DEAL", "UPDATE_ENTITY", "CREATE_CAPITAL_CALL"
  targetType String   // e.g. "Deal", "Entity", "CapitalCall"
  targetId   String
  metadata   Json?    // { before, after, description, ... }
  createdAt  DateTime @default(now())

  firm       Firm     @relation(fields: [firmId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@index([firmId])
  @@index([userId])
  @@index([targetType, targetId])
  @@index([createdAt])
  // Optimizes: GET /api/audit-logs?firmId=xxx&startDate=...&endDate=... (time-range queries per firm)
  @@index([firmId, createdAt])
}

// ============================================================
// THIRD-PARTY INTEGRATIONS (Phase 7)
// ============================================================

model IntegrationConnection {
  id                  String    @id @default(cuid())
  firmId              String
  provider            String    // "asana" | "notion" | "google_calendar" | "plaid"
  entityId            String?   // for per-entity integrations (Plaid)
  accessToken         String
  refreshToken        String?
  tokenExpiry         DateTime?
  externalAccountId   String?   // provider-specific account/workspace ID
  metadata            Json?     // provider-specific config (workspace ID, project ID, etc.)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  firm                Firm      @relation(fields: [firmId], references: [id])
  plaidAccounts       PlaidAccount[]

  @@unique([firmId, provider, entityId])
  @@index([firmId])
}

model PlaidAccount {
  id               String   @id @default(cuid())
  connectionId     String
  accountId        String   // Plaid account_id
  name             String
  type             String   // checking, savings, etc.
  subtype          String?
  currentBalance   Float?
  availableBalance Float?
  lastSynced       DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  connection       IntegrationConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([connectionId, accountId])
  @@index([connectionId])
}

// ============================================================
// PAYMENTS (Phase A — Dwolla + Plaid)
// ============================================================

/// How a capital call line item or distribution line item was paid.
enum PaymentMethod {
  DWOLLA_ACH
  EXTERNAL_WIRE
  EXTERNAL_CHECK
  EXTERNAL_OTHER
}

/// Lifecycle of a single payment leg.
/// PENDING      — created locally, not yet submitted to processor
/// PROCESSED    — accepted by Dwolla and in flight (ACH clearing)
/// COMPLETED    — settled / funds landed in destination
/// FAILED       — processor returned a failure (NSF, R01, account closed, etc.)
/// CANCELLED    — cancelled before processor accepted (user action)
enum PaymentStatus {
  PENDING
  PROCESSED
  COMPLETED
  FAILED
  CANCELLED
}

/// Status of the Dwolla-side verified customer record for an investor.
enum DwollaCustomerStatus {
  UNVERIFIED
  RETRY
  DOCUMENT
  VERIFIED
  SUSPENDED
  DEACTIVATED
}

/// Status of a linked bank account (funding source) in Dwolla.
enum FundingSourceStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REMOVED
}

/// An outbound disbursement bank account Atlas uses to fund distributions for a given entity.
/// Example: PCF II → Citi operating account; Silver Horse → Chase.
/// Each entity can have multiple funding sources; exactly one is marked isDefault for automatic use.
model EntityFundingSource {
  id                    String   @id @default(cuid())
  entityId              String
  dwollaFundingSourceId String   @unique // Dwolla funding source URL suffix (the id portion)
  dwollaCustomerId      String   // The Dwolla Verified Business Customer URL this source hangs off
  bankName              String
  accountNickname       String?  // e.g. "Citi Operating" set by Kathryn
  accountType           String?  // checking | savings
  last4                 String?
  status                FundingSourceStatus @default(UNVERIFIED)
  isDefault             Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  entity Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@index([entityId])
  @@index([status])
}

/// Dwolla "Verified Personal Customer" or "Receive-Only Customer" record per investor.
/// Required before we can credit the investor via ACH. Created on first bank link attempt.
model InvestorDwollaCustomer {
  id                String   @id @default(cuid())
  investorId        String   @unique
  dwollaCustomerId  String   @unique // Dwolla customer URL id
  customerType      String   // "personal" | "business" | "receive-only" | "unverified"
  status            DwollaCustomerStatus @default(UNVERIFIED)
  email             String
  firstName         String?
  lastName          String?
  businessName      String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  investor Investor @relation(fields: [investorId], references: [id], onDelete: Cascade)

  @@index([status])
}

/// An investor's linked bank account (funding source) used to receive distributions
/// and optionally fund capital calls. Never stores the raw routing/account number —
/// Atlas only holds the Dwolla funding source id; Plaid + Dwolla hold the underlying credentials.
model InvestorPaymentMethod {
  id                    String   @id @default(cuid())
  investorId            String
  dwollaFundingSourceId String   @unique
  bankName              String
  accountNickname       String?  // user-set label
  accountType           String?  // checking | savings
  last4                 String?
  status                FundingSourceStatus @default(UNVERIFIED)
  isDefault             Boolean  @default(false)
  plaidAccountId        String?  // Plaid account_id that backs this funding source (for reference)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  investor Investor @relation(fields: [investorId], references: [id], onDelete: Cascade)

  @@index([investorId])
  @@index([status])
}

// ============================================================
// LP METRIC SNAPSHOTS (Phase 6)
// ============================================================

model MetricSnapshot {
  id               String   @id @default(cuid())
  investorId       String
  entityId         String   @default("__AGGREGATE__") // "__AGGREGATE__" for portfolio-wide, real entityId for per-entity
  periodDate       DateTime // snapshot date (truncated to midnight UTC)
  irr              Float?
  tvpi             Float?
  dpi              Float?
  rvpi             Float?
  nav              Float?
  totalCalled      Float?
  totalDistributed Float?
  createdAt        DateTime @default(now())

  investor Investor @relation(fields: [investorId], references: [id])

  @@unique([investorId, entityId, periodDate])
  @@index([investorId, periodDate])
}

